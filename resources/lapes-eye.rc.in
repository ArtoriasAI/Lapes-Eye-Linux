// Windows Resource File — ikona aplikacji w EXE i pasku zadań
IDI_ICON1 ICON "@CMAKE_SOURCE_DIR@/resources/icons/lapes-eye.ico"

// Informacje o wersji
1 VERSIONINFO
FILEVERSION 0,5,0,0
PRODUCTVERSION 0,5,0,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Lape Photography Tools"
            VALUE "FileDescription",  "Lape's Eye — Photo Browser"
            VALUE "FileVersion",      "0.5.0.0"
            VALUE "InternalName",     "lapes-eye"
            VALUE "LegalCopyright",   "Copyright 2025"
            VALUE "OriginalFilename", "lapes-eye.exe"
            VALUE "ProductName",      "Lape's Eye"
            VALUE "ProductVersion",   "0.5.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
